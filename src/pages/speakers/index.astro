---
import Layout from "@/layout/Layout.astro"
import { getEntry } from "astro:content"

const speaker = await getEntry("speakers", "demyan-sluzhenie")
const audioSrc = "/audio/speakers/demyan_2.mp3"
---

<Layout
	title="Спикерские"
	desc="Спикерские выступления членов АИЗ — опыт выздоровления от интернет-зависимости."
>
	<h1 class="text-3xl font-bold mb-2">Спикерские</h1>

	<div class="max-w-2xl">
		{speaker && (
			<div class="speaker-row border-b border-zinc-100">
				<div class="flex items-center justify-between gap-4 py-3">
					<div class="flex items-baseline gap-4 min-w-0">
						<span class="font-semibold text-zinc-900 whitespace-nowrap">Демьян</span>
						<span class="text-zinc-500 truncate">Служение</span>
					</div>
					<button
						class="listen-btn whitespace-nowrap text-[#0098EA] underline underline-offset-2 text-sm shrink-0 cursor-pointer bg-transparent border-none"
						aria-expanded="false"
					>
						Слушать
					</button>
				</div>

				<div class="player-wrap hidden pb-3">
					<audio controls class="w-full" src={audioSrc}>
						Ваш браузер не поддерживает аудио.
					</audio>
				</div>
			</div>
		)}
	</div>
</Layout>

<script>
	document.querySelectorAll<HTMLButtonElement>(".listen-btn").forEach((btn) => {
		btn.addEventListener("click", () => {
			const row = btn.closest(".speaker-row")!
			const player = row.querySelector<HTMLElement>(".player-wrap")!
			const open = player.classList.toggle("hidden")
			btn.setAttribute("aria-expanded", String(!open))
		})
	})
</script>
