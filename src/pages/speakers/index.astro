---
import Layout from "@/layout/Layout.astro"
import { SPEAKERS } from "@/data/speakers"

const PAGE_SIZE = 10
const totalPages = Math.ceil(SPEAKERS.length / PAGE_SIZE)

// Последние записи первыми: реверс, затем разбивка на страницы
const reversed = [...SPEAKERS].reverse()
const pages = Array.from({ length: totalPages }, (_, i) =>
	reversed.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE)
)
---

<Layout
	title="Спикерские"
	desc="Спикерские выступления членов АИЗ — опыт выздоровления от интернет-зависимости."
>
	<h1 class="text-3xl font-bold mb-4">Спикерские</h1>

	<p class="text-zinc-500 text-base border-l-4 border-zinc-200 pl-4 mb-6 leading-relaxed">
		Спикерские выступления членов АИЗ.<br />
		Рассказы в этом разделе отображают личный опыт и мнение отдельных авторов, а не сообщества АИЗ в целом.
	</p>

	{pages.map((page, pageIndex) => (
		<div
			id={`page-${pageIndex}`}
			class:list={["speakers-page rounded-xl overflow-hidden border border-zinc-200 mb-6", pageIndex !== 0 && "hidden"]}
		>
			{page.map((s, i) => (
				<div class={`speaker-row ${i % 2 === 0 ? "bg-white" : "bg-zinc-50"}`}>
					<div class="flex items-center justify-between gap-4 px-4 py-4">
						<span class="font-bold text-xl text-zinc-900 whitespace-nowrap shrink-0">{s.speaker}</span>
						<span class="text-lg text-zinc-500 grow min-w-0 truncate px-3">{s.title}</span>
						{s.ext && (
							<button
								class="listen-btn whitespace-nowrap text-lg text-[#0098EA] underline underline-offset-2 shrink-0 cursor-pointer bg-transparent border-none"
								data-src={`/audio/speakers/${s.code}.${s.ext}`}
								aria-expanded="false"
							>
								Слушать
							</button>
						)}
					</div>
					<div class="player-wrap hidden px-4 pb-4">
						<audio controls class="w-full"></audio>
					</div>
				</div>
			))}
		</div>
	))}

	{totalPages > 1 && (
		<div class="flex gap-2 flex-wrap">
			{pages.map((_, i) => (
				<button
					class:list={[
						"page-btn px-4 py-2 rounded-lg text-base border transition-colors",
						i === 0
							? "bg-[#0098EA] text-white border-[#0098EA]"
							: "bg-white text-zinc-600 border-zinc-200 hover:border-[#0098EA] hover:text-[#0098EA]"
					]}
					data-page={i}
				>
					{i + 1}
				</button>
			))}
		</div>
	)}
</Layout>

<script>
	// Плеер
	document.querySelectorAll<HTMLButtonElement>(".listen-btn").forEach((btn) => {
		btn.addEventListener("click", () => {
			const row = btn.closest(".speaker-row")!
			const wrap = row.querySelector<HTMLElement>(".player-wrap")!
			const audio = wrap.querySelector<HTMLAudioElement>("audio")!
			const isOpen = !wrap.classList.contains("hidden")

			if (isOpen) {
				audio.pause()
				wrap.classList.add("hidden")
				btn.setAttribute("aria-expanded", "false")
			} else {
				if (!audio.src) audio.src = btn.dataset.src!
				wrap.classList.remove("hidden")
				btn.setAttribute("aria-expanded", "true")
				audio.play()
			}
		})
	})

	// Пагинация
	const pageBtns = document.querySelectorAll<HTMLButtonElement>(".page-btn")
	const pageBlocks = document.querySelectorAll<HTMLElement>(".speakers-page")

	pageBtns.forEach((btn) => {
		btn.addEventListener("click", () => {
			const target = Number(btn.dataset.page)

			pageBlocks.forEach((block, i) => block.classList.toggle("hidden", i !== target))

			pageBtns.forEach((b) => {
				const active = Number(b.dataset.page) === target
				b.classList.toggle("bg-[#0098EA]", active)
				b.classList.toggle("text-white", active)
				b.classList.toggle("border-[#0098EA]", active)
				b.classList.toggle("bg-white", !active)
				b.classList.toggle("text-zinc-600", !active)
			})
		})
	})
</script>
