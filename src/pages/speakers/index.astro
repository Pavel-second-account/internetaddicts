---
import Layout from "@/layout/Layout.astro"
import { SPEAKERS, SPEAKER_TAGS, CLOUD_BASE } from "@/data/speakers"

const reversed = [...SPEAKERS].reverse()
---

<Layout
	title="Спикерские"
	desc="Спикерские выступления членов АИЗ — опыт выздоровления от интернет-зависимости."
>
	<h1 class="text-3xl font-bold mb-4">Спикерские</h1>

	<p class="text-zinc-500 text-xl border-l-4 border-zinc-200 pl-4 mb-6 leading-relaxed">
		Спикерские выступления членов АИЗ.<br />
		Рассказы в этом разделе отображают личный опыт и мнение отдельных авторов, а не сообщества АИЗ в целом.
	</p>

	<div class="flex flex-wrap gap-2 mb-6">
		<button class="tag-btn px-3 py-1 rounded-full text-sm border transition-colors bg-[#0098EA] text-white border-[#0098EA]" data-tag="">
			Все
		</button>
		{SPEAKER_TAGS.map(tag => (
			<button class="tag-btn px-3 py-1 rounded-full text-sm border transition-colors bg-white text-zinc-600 border-zinc-200 hover:border-[#0098EA] hover:text-[#0098EA]" data-tag={tag}>
				{tag}
			</button>
		))}
	</div>

	<div class="rounded-xl overflow-hidden border border-zinc-200 mb-6">
		<div class="flex items-center gap-4 px-4 py-2 bg-zinc-100 border-b border-zinc-200">
			<span class="font-semibold text-sm text-zinc-400 uppercase tracking-wide w-40 shrink-0">Автор</span>
			<span class="font-semibold text-sm text-zinc-400 uppercase tracking-wide grow">Тема</span>
			<span class="w-20 shrink-0" />
			<span class="w-12 shrink-0" />
		</div>

		{reversed.map((s) => (
			<div
				class="speaker-row hidden"
				data-tags={s.tags.join("|")}
			>
				<div class="flex flex-col md:flex-row md:items-center gap-1 md:gap-4 px-4 py-4">
					<span class="font-bold text-xl text-zinc-900 md:whitespace-nowrap md:shrink-0 md:w-40">{s.speaker}</span>
					<span class="text-lg text-zinc-500 md:grow min-w-0">{s.title}</span>
					{s.ext && (
						<div class="flex gap-4 shrink-0 mt-1 md:mt-0">
							<button
								class="listen-btn whitespace-nowrap text-lg text-[#0098EA] underline underline-offset-2 cursor-pointer bg-transparent border-none"
								data-src={`/audio/speakers/${s.code}.${s.ext}`}
								aria-expanded="false"
							>
								Слушать
							</button>
							<a
								href={`${CLOUD_BASE}/${s.code}.${s.ext}`}
								target="_blank"
								rel="noopener noreferrer"
								class="text-lg text-[#0098EA] underline underline-offset-2 whitespace-nowrap"
							>
								Диск
							</a>
						</div>
					)}
				</div>
				<div class="player-wrap hidden px-4 pb-4">
					<audio controls class="w-full"></audio>
				</div>
			</div>
		))}

		<p id="no-results" class="hidden px-4 py-8 text-center text-zinc-400">Нет записей по этому тегу.</p>
	</div>

	<div id="pagination" class="flex gap-2 flex-wrap"></div>
</Layout>

<script>
	const PAGE_SIZE = 10

	const allRows = Array.from(document.querySelectorAll<HTMLElement>(".speaker-row"))
	const paginationEl = document.getElementById("pagination")!
	const noResults = document.getElementById("no-results")!

	let activeTag = ""
	let currentPage = 0

	function getFiltered(): HTMLElement[] {
		if (!activeTag) return allRows
		return allRows.filter(row => {
			const tags = (row.dataset.tags ?? "").split("|").filter(Boolean)
			return tags.includes(activeTag)
		})
	}

	function applyColors(visibleRows: HTMLElement[]) {
		visibleRows.forEach((row, i) => {
			row.classList.toggle("bg-white", i % 2 === 0)
			row.classList.toggle("bg-zinc-50", i % 2 !== 0)
		})
	}

	function renderPage(page: number) {
		currentPage = page
		const filtered = getFiltered()
		const totalPages = Math.ceil(filtered.length / PAGE_SIZE)
		const pageRows = filtered.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE)

		// Hide all, show page slice
		allRows.forEach(r => r.classList.add("hidden"))
		pageRows.forEach(r => r.classList.remove("hidden"))
		applyColors(pageRows)

		noResults.classList.toggle("hidden", filtered.length > 0)

		// Rebuild pagination
		paginationEl.innerHTML = ""
		if (totalPages > 1) {
			for (let i = 0; i < totalPages; i++) {
				const btn = document.createElement("button")
				btn.textContent = String(i + 1)
				btn.dataset.page = String(i)
				btn.className = [
					"page-btn px-4 py-2 rounded-lg text-base border transition-colors",
					i === page
						? "bg-[#0098EA] text-white border-[#0098EA]"
						: "bg-white text-zinc-600 border-zinc-200 hover:border-[#0098EA] hover:text-[#0098EA]",
				].join(" ")
				btn.addEventListener("click", () => renderPage(i))
				paginationEl.appendChild(btn)
			}
		}
	}

	// Tag filter buttons
	document.querySelectorAll<HTMLButtonElement>(".tag-btn").forEach(btn => {
		btn.addEventListener("click", () => {
			activeTag = btn.dataset.tag ?? ""
			document.querySelectorAll<HTMLButtonElement>(".tag-btn").forEach(b => {
				const isActive = b === btn
				b.classList.toggle("bg-[#0098EA]", isActive)
				b.classList.toggle("text-white", isActive)
				b.classList.toggle("border-[#0098EA]", isActive)
				b.classList.toggle("bg-white", !isActive)
				b.classList.toggle("text-zinc-600", !isActive)
			})
			renderPage(0)
		})
	})

	// Audio player
	allRows.forEach(row => {
		const btn = row.querySelector<HTMLButtonElement>(".listen-btn")
		if (!btn) return
		btn.addEventListener("click", () => {
			const wrap = row.querySelector<HTMLElement>(".player-wrap")!
			const audio = wrap.querySelector<HTMLAudioElement>("audio")!
			const isOpen = !wrap.classList.contains("hidden")
			if (isOpen) {
				audio.pause()
				wrap.classList.add("hidden")
				btn.setAttribute("aria-expanded", "false")
			} else {
				if (!audio.src) audio.src = btn.dataset.src!
				wrap.classList.remove("hidden")
				btn.setAttribute("aria-expanded", "true")
				audio.play()
			}
		})
	})

	// Init: show first page
	renderPage(0)
</script>
