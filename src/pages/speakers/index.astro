---
import Layout from "@/layout/Layout.astro"
import { SPEAKERS, SPEAKER_TAGS, CLOUD_BASE } from "@/data/speakers"

const PAGE_SIZE = 10
const totalPages = Math.ceil(SPEAKERS.length / PAGE_SIZE)

const reversed = [...SPEAKERS].reverse()
const pages = Array.from({ length: totalPages }, (_, i) =>
	reversed.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE)
)
---

<Layout
	title="Спикерские"
	desc="Спикерские выступления членов АИЗ — опыт выздоровления от интернет-зависимости."
>
	<h1 class="text-3xl font-bold mb-4">Спикерские</h1>

	<p class="text-zinc-500 text-xl border-l-4 border-zinc-200 pl-4 mb-6 leading-relaxed">
		Спикерские выступления членов АИЗ.<br />
		Рассказы в этом разделе отображают личный опыт и мнение отдельных авторов, а не сообщества АИЗ в целом.
	</p>

	<div class="flex flex-wrap gap-2 mb-6">
		<button class="tag-btn active-tag px-3 py-1 rounded-full text-sm border transition-colors bg-[#0098EA] text-white border-[#0098EA]" data-tag="">
			Все
		</button>
		{SPEAKER_TAGS.map(tag => (
			<button class="tag-btn px-3 py-1 rounded-full text-sm border transition-colors bg-white text-zinc-600 border-zinc-200 hover:border-[#0098EA] hover:text-[#0098EA]" data-tag={tag}>
				{tag}
			</button>
		))}
	</div>

	{pages.map((page, pageIndex) => (
		<div
			id={`page-${pageIndex}`}
			class:list={["speakers-page rounded-xl overflow-hidden border border-zinc-200 mb-6", pageIndex !== 0 && "hidden"]}
		>
			<div class="flex items-center gap-4 px-4 py-2 bg-zinc-100 border-b border-zinc-200">
				<span class="font-semibold text-sm text-zinc-400 uppercase tracking-wide w-40 shrink-0">Автор</span>
				<span class="font-semibold text-sm text-zinc-400 uppercase tracking-wide grow">Тема</span>
				<span class="w-20 shrink-0" />
				<span class="w-12 shrink-0" />
			</div>

			{page.map((s, i) => (
				<div
					class={`speaker-row ${i % 2 === 0 ? "bg-white" : "bg-zinc-50"}`}
					data-tags={s.tags.join("|")}
				>
					<div class="flex items-center gap-4 px-4 py-4">
						<span class="font-bold text-xl text-zinc-900 whitespace-nowrap shrink-0 w-40">{s.speaker}</span>
						<span class="text-lg text-zinc-500 grow min-w-0 truncate">
							{s.title}
						</span>
						<div class="w-20 shrink-0 flex justify-end">
							{s.ext && (
								<button
									class="listen-btn whitespace-nowrap text-lg text-[#0098EA] underline underline-offset-2 cursor-pointer bg-transparent border-none"
									data-src={`/audio/speakers/${s.code}.${s.ext}`}
									aria-expanded="false"
								>
									Слушать
								</button>
							)}
						</div>
						<div class="w-12 shrink-0 flex justify-end">
							{s.ext && (
								<a
									href={`${CLOUD_BASE}/${s.code}.${s.ext}`}
									target="_blank"
									rel="noopener noreferrer"
									class="text-lg text-[#0098EA] underline underline-offset-2 whitespace-nowrap"
								>
									Диск
								</a>
							)}
						</div>
					</div>
					<div class="player-wrap hidden px-4 pb-4">
						<audio controls class="w-full"></audio>
					</div>
				</div>
			))}
		</div>
	))}

	{totalPages > 1 && (
		<div id="pagination" class="flex gap-2 flex-wrap">
			{pages.map((_, i) => (
				<button
					class:list={[
						"page-btn px-4 py-2 rounded-lg text-base border transition-colors",
						i === 0
							? "bg-[#0098EA] text-white border-[#0098EA]"
							: "bg-white text-zinc-600 border-zinc-200 hover:border-[#0098EA] hover:text-[#0098EA]"
					]}
					data-page={i}
				>
					{i + 1}
				</button>
			))}
		</div>
	)}
</Layout>

<script>
	// Плеер
	document.querySelectorAll<HTMLButtonElement>(".listen-btn").forEach((btn) => {
		btn.addEventListener("click", () => {
			const row = btn.closest(".speaker-row")!
			const wrap = row.querySelector<HTMLElement>(".player-wrap")!
			const audio = wrap.querySelector<HTMLAudioElement>("audio")!
			const isOpen = !wrap.classList.contains("hidden")

			if (isOpen) {
				audio.pause()
				wrap.classList.add("hidden")
				btn.setAttribute("aria-expanded", "false")
			} else {
				if (!audio.src) audio.src = btn.dataset.src!
				wrap.classList.remove("hidden")
				btn.setAttribute("aria-expanded", "true")
				audio.play()
			}
		})
	})

	// Пагинация
	const pageBtns = document.querySelectorAll<HTMLButtonElement>(".page-btn")
	const pageBlocks = document.querySelectorAll<HTMLElement>(".speakers-page")
	const pagination = document.getElementById("pagination")

	let currentPage = 0
	let activeTag = ""

	function showPage(idx: number) {
		currentPage = idx
		pageBlocks.forEach((block, i) => block.classList.toggle("hidden", i !== idx))
		pageBtns.forEach((b) => {
			const active = Number(b.dataset.page) === idx
			b.classList.toggle("bg-[#0098EA]", active)
			b.classList.toggle("text-white", active)
			b.classList.toggle("border-[#0098EA]", active)
			b.classList.toggle("bg-white", !active)
			b.classList.toggle("text-zinc-600", !active)
		})
	}

	function applyFilter(tag: string) {
		activeTag = tag
		const allRows = document.querySelectorAll<HTMLElement>(".speaker-row")

		if (!tag) {
			// Сбрасываем фильтр — показываем пагинацию, скрываем все строки кроме текущей страницы
			allRows.forEach((row) => row.classList.remove("hidden"))
			if (pagination) pagination.classList.remove("hidden")
			showPage(0)
		} else {
			// Показываем все страницы, скрываем строки не по тегу
			pageBlocks.forEach((block) => block.classList.remove("hidden"))
			if (pagination) pagination.classList.add("hidden")
			allRows.forEach((row) => {
				const tags = (row.dataset.tags ?? "").split("|").filter(Boolean)
				row.classList.toggle("hidden", !tags.includes(tag))
			})
		}
	}

	pageBtns.forEach((btn) => {
		btn.addEventListener("click", () => showPage(Number(btn.dataset.page)))
	})

	document.querySelectorAll<HTMLButtonElement>(".tag-btn").forEach((btn) => {
		btn.addEventListener("click", () => {
			document.querySelectorAll<HTMLButtonElement>(".tag-btn").forEach((b) => {
				const isActive = b === btn
				b.classList.toggle("bg-[#0098EA]", isActive)
				b.classList.toggle("text-white", isActive)
				b.classList.toggle("border-[#0098EA]", isActive)
				b.classList.toggle("bg-white", !isActive)
				b.classList.toggle("text-zinc-600", !isActive)
			})
			applyFilter(btn.dataset.tag ?? "")
		})
	})
</script>
