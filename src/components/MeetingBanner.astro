---
const DISMISS_PREFIX = "meeting_dismissed_"
---

<div
	id="meeting-banner"
	class="fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300"
	role="status"
	aria-live="polite"
>
	<div class="bg-[#0098EA] text-white px-4 py-3 flex items-center justify-between gap-4 flex-wrap shadow-[0_-2px_12px_rgba(0,0,0,0.15)]">
		<p id="meeting-banner-text" class="text-base font-medium leading-snug"></p>
		<button
			id="meeting-banner-close"
			type="button"
			class="shrink-0 text-white/80 hover:text-white text-xl leading-none px-1"
			aria-label="Закрыть"
		>×</button>
	</div>
</div>

<script define:vars={{ DISMISS_PREFIX }}>
	const AIZ = {
		zoom: "https://us06web.zoom.us/j/86283420410?pwd=WAEyY3dcElfcgFseI9Y7Y8qYNZyRG9.1",
		chat: "https://t.me/aiz_meetings/9057",
	}
	const AKI = {
		zoom: null,
		chat: "https://t.me/cgaa_cis/8119",
	}

	const MEETINGS_MSK = [
		{ day: 0, hour: 20, min: 0, ...AKI },
		{ day: 1, hour: 10, min: 0, ...AIZ },
		{ day: 1, hour: 20, min: 0, ...AKI },
		{ day: 2, hour: 12, min: 0, ...AIZ },
		{ day: 3, hour: 12, min: 0, ...AIZ },
		{ day: 4, hour: 10, min: 0, ...AIZ },
		{ day: 4, hour: 20, min: 0, ...AIZ },
		{ day: 5, hour: 9,  min: 0, ...AIZ },
	]
	const DURATION_MIN = 60

	function getMskDate() {
		const now = new Date()
		const mskOffset = 3 * 60
		const localOffset = -now.getTimezoneOffset()
		return new Date(now.getTime() + (mskOffset - localOffset) * 60_000)
	}

	function getActiveMeeting() {
		const msk = getMskDate()
		const day = msk.getDay()
		const minutes = msk.getHours() * 60 + msk.getMinutes()
		return MEETINGS_MSK.find(({ day: d, hour, min }) => {
			const start = hour * 60 + min
			return day === d && minutes >= start && minutes < start + DURATION_MIN
		}) ?? null
	}

	function dismissKey(meeting) {
		const msk = getMskDate()
		return `${DISMISS_PREFIX}${msk.toISOString().slice(0, 10)}_${meeting.day}_${meeting.hour}`
	}

	function mkLink(href, label) {
		return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold hover:opacity-80">${label}</a>`
	}

	const banner = document.getElementById("meeting-banner")
	const textEl = document.getElementById("meeting-banner-text")
	const closeBtn = document.getElementById("meeting-banner-close")
	const meeting = getActiveMeeting()

	if (banner && textEl && meeting && !localStorage.getItem(dismissKey(meeting))) {
		const parts = ["Сейчас идёт онлайн-собрание. Заходите —"]
		if (meeting.zoom) parts.push(mkLink(meeting.zoom, "Zoom"))
		parts.push(mkLink(meeting.chat, "Чат"))
		textEl.innerHTML = parts.join(" ")

		requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				banner.classList.remove("translate-y-full")
			})
		})
	}

	closeBtn?.addEventListener("click", () => {
		if (meeting) localStorage.setItem(dismissKey(meeting), "1")
		banner?.classList.add("translate-y-full")
	})
</script>
